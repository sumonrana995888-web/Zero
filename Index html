<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zero — Next-Gen Software Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --blue:       #3d8fe0;
  --blue-light: #5aadff;
  --blue-dark:  #1a5fa3;
  --bg:         #080b12;
  --bg2:        #0d1220;
  --bg3:        #111827;
  --border:     rgba(61,143,224,0.18);
  --text:       #e8edf5;
  --muted:      rgba(232,237,245,0.45);
  --white:      #ffffff;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Inter',sans-serif;
  overflow-x:hidden;
  cursor:none;
}

/* ── CURSOR ── */
#cur{
  width:10px;height:10px;
  background:var(--blue-light);
  border-radius:50%;
  position:fixed;top:0;left:0;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:width .25s,height .25s;
  mix-blend-mode:screen;
}
#curR{
  width:32px;height:32px;
  border:1.5px solid rgba(90,173,255,.45);
  border-radius:50%;
  position:fixed;top:0;left:0;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
}
body:hover #cur{opacity:1}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:200;
  padding:0 5vw;
  height:68px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(8,11,18,.85);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.nav-logo{
  display:flex;align-items:center;gap:10px;
  text-decoration:none;
}
.nav-logo img{width:32px;height:32px;object-fit:contain;filter:brightness(0) invert(1)}
.nav-logo span{
  font-family:'Syne',sans-serif;
  font-size:1.35rem;font-weight:800;
  color:var(--white);letter-spacing:.04em;
}
.nav-logo span em{color:var(--blue-light);font-style:normal}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{
  font-size:.85rem;font-weight:500;letter-spacing:.04em;
  color:var(--muted);text-decoration:none;
  transition:color .2s;
}
.nav-links a:hover{color:var(--white)}
.nav-right{display:flex;gap:.75rem;align-items:center}
.btn-ghost{
  font-size:.82rem;font-weight:600;letter-spacing:.04em;
  color:var(--text);border:1px solid var(--border);
  padding:.5rem 1.1rem;border-radius:8px;text-decoration:none;
  transition:all .2s;
}
.btn-ghost:hover{border-color:var(--blue);color:var(--white)}
.btn-primary{
  font-size:.82rem;font-weight:600;letter-spacing:.04em;
  background:var(--blue);color:#fff;
  padding:.5rem 1.3rem;border-radius:8px;text-decoration:none;
  box-shadow:0 0 20px rgba(61,143,224,.35);
  transition:all .2s;
}
.btn-primary:hover{background:var(--blue-light);box-shadow:0 0 30px rgba(90,173,255,.5)}

/* ── HERO ── */
.hero{
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
  padding:100px 5vw 60px;
}
/* animated mesh bg */
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 55% 55% at 20% 50%, rgba(61,143,224,.14) 0%,transparent 65%),
    radial-gradient(ellipse 40% 50% at 80% 40%, rgba(26,95,163,.1) 0%,transparent 65%),
    radial-gradient(ellipse 60% 40% at 50% 100%, rgba(13,18,32,.8) 0%,transparent 60%);
}
/* grid */
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(var(--border) 1px,transparent 1px),
    linear-gradient(90deg,var(--border) 1px,transparent 1px);
  background-size:70px 70px;
  mask-image:radial-gradient(ellipse 80% 80% at 50% 40%,black 30%,transparent 80%);
}
.hero-inner{
  max-width:1100px;width:100%;margin:0 auto;
  display:grid;grid-template-columns:1fr 1fr;
  gap:4rem;align-items:center;
  position:relative;z-index:2;
}
.hero-left{}
.hero-badge{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(61,143,224,.1);
  border:1px solid rgba(61,143,224,.3);
  border-radius:50px;padding:.35rem 1rem .35rem .5rem;
  font-size:.72rem;font-weight:600;letter-spacing:.1em;
  text-transform:uppercase;color:var(--blue-light);
  margin-bottom:1.6rem;
  animation:fadeUp .7s ease both;
}
.hero-badge-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--blue-light);
  box-shadow:0 0 8px var(--blue-light);
  animation:dotBlink 1.5s ease-in-out infinite;
}
@keyframes dotBlink{0%,100%{opacity:1}50%{opacity:.3}}
.hero-title{
  font-family:'Syne',sans-serif;
  font-size:clamp(2.6rem,4.5vw,4rem);
  font-weight:800;line-height:1.08;
  letter-spacing:-.02em;
  color:var(--white);
  margin-bottom:1.4rem;
  animation:fadeUp .8s ease .1s both;
}
.hero-title .grad{
  background:linear-gradient(135deg,#fff 30%,var(--blue-light));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.hero-desc{
  font-size:1rem;line-height:1.75;color:var(--muted);
  max-width:460px;margin-bottom:2.2rem;font-weight:400;
  animation:fadeUp .8s ease .2s both;
}
.hero-actions{
  display:flex;gap:1rem;flex-wrap:wrap;
  animation:fadeUp .8s ease .3s both;
}
.hero-btn-p{
  display:inline-flex;align-items:center;gap:.5rem;
  background:var(--blue);color:#fff;
  font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;
  padding:.75rem 1.8rem;border-radius:10px;text-decoration:none;
  box-shadow:0 0 30px rgba(61,143,224,.4);
  transition:all .25s;
}
.hero-btn-p:hover{background:var(--blue-light);transform:translateY(-2px);box-shadow:0 6px 35px rgba(90,173,255,.5)}
.hero-btn-g{
  display:inline-flex;align-items:center;gap:.5rem;
  border:1px solid var(--border);color:var(--text);
  font-size:.9rem;font-weight:600;
  padding:.75rem 1.8rem;border-radius:10px;text-decoration:none;
  transition:all .25s;
}
.hero-btn-g:hover{border-color:var(--blue);color:var(--white);background:rgba(61,143,224,.07)}
.hero-stats{
  display:flex;gap:2.5rem;margin-top:3rem;
  animation:fadeUp .8s ease .5s both;
}
.hstat-num{
  font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;
  color:var(--white);line-height:1;
}
.hstat-lbl{font-size:.75rem;color:var(--muted);margin-top:.2rem;letter-spacing:.05em}

/* hero right – big logo display */
.hero-right{
  display:flex;align-items:center;justify-content:center;
  position:relative;
  animation:fadeUp .9s ease .2s both;
}
.hero-logo-wrap{
  position:relative;
  width:380px;height:380px;
  display:flex;align-items:center;justify-content:center;
}
/* rings */
.h-ring{
  position:absolute;border-radius:50%;
  border:1px solid rgba(61,143,224,.18);
  animation:ringPulse 4s ease-in-out infinite;
}
.h-ring:nth-child(1){width:280px;height:280px;animation-delay:0s}
.h-ring:nth-child(2){width:340px;height:340px;animation-delay:.8s;border-color:rgba(61,143,224,.1)}
.h-ring:nth-child(3){width:380px;height:380px;animation-delay:1.6s;border-color:rgba(61,143,224,.06)}
@keyframes ringPulse{0%,100%{transform:scale(1);opacity:.7}50%{transform:scale(1.04);opacity:1}}
.h-glow{
  position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(61,143,224,.18) 0%,transparent 70%);
  border-radius:50%;
  animation:glowPulse 3s ease-in-out infinite;
}
@keyframes glowPulse{0%,100%{opacity:.6}50%{opacity:1}}
.hero-logo-img{
  width:240px;position:relative;z-index:2;
  filter:drop-shadow(0 0 30px rgba(61,143,224,.7)) drop-shadow(0 0 60px rgba(61,143,224,.3));
  animation:logoFloat 5s ease-in-out infinite;
}
@keyframes logoFloat{0%,100%{transform:translateY(0) rotate(-2deg)}50%{transform:translateY(-15px) rotate(2deg)}}

@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

/* ── LOGOS STRIP ── */
.logos-strip{
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  padding:1.6rem 5vw;
  display:flex;align-items:center;justify-content:center;gap:1rem;
  background:var(--bg2);overflow:hidden;
}
.strip-label{font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);white-space:nowrap;margin-right:1.5rem}
.logos-track{display:flex;gap:3.5rem;align-items:center;animation:logoScroll 22s linear infinite}
@keyframes logoScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.lgo{
  font-family:'Syne',sans-serif;font-size:.85rem;font-weight:700;
  color:rgba(255,255,255,.2);letter-spacing:.08em;white-space:nowrap;
  transition:color .3s;
}
.lgo:hover{color:rgba(255,255,255,.55)}

/* ── SECTION COMMON ── */
.section{padding:6rem 5vw;max-width:1200px;margin:0 auto}
.sec-tag{
  display:inline-block;
  font-size:.68rem;font-weight:600;letter-spacing:.18em;text-transform:uppercase;
  color:var(--blue-light);margin-bottom:.8rem;
}
.sec-title{
  font-family:'Syne',sans-serif;font-size:clamp(1.9rem,3.2vw,2.9rem);
  font-weight:800;color:var(--white);line-height:1.15;
  letter-spacing:-.02em;margin-bottom:1rem;
}
.sec-desc{font-size:1rem;color:var(--muted);line-height:1.7;max-width:520px}

/* ── SERVICES ── */
.services-bg{background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.services-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1px;
  background:var(--border);margin-top:4rem;border:1px solid var(--border);border-radius:16px;overflow:hidden;
}
.srv-card{
  background:var(--bg2);padding:2.5rem 2rem;
  position:relative;overflow:hidden;
  transition:background .3s;
}
.srv-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--blue-dark),var(--blue-light));
  transform:scaleX(0);transform-origin:left;transition:transform .4s;
}
.srv-card:hover{background:rgba(61,143,224,.05)}
.srv-card:hover::before{transform:scaleX(1)}
.srv-icon{
  width:48px;height:48px;border-radius:12px;
  background:rgba(61,143,224,.12);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;margin-bottom:1.4rem;
}
.srv-title{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;color:var(--white);margin-bottom:.6rem}
.srv-desc{font-size:.88rem;color:var(--muted);line-height:1.65}
.srv-num{
  position:absolute;bottom:1.5rem;right:1.8rem;
  font-family:'Syne',sans-serif;font-size:.65rem;font-weight:800;
  color:rgba(61,143,224,.2);letter-spacing:.1em;
}

/* ── FEATURES ── */
.features-inner{
  display:grid;grid-template-columns:1fr 1fr;
  gap:5rem;align-items:center;margin-top:4rem;
}
.feat-visual{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:20px;overflow:hidden;position:relative;
  height:400px;
}
.feat-visual-glow{
  position:absolute;inset:0;
  background:radial-gradient(ellipse 70% 50% at 50% 50%,rgba(61,143,224,.15) 0%,transparent 70%);
}
.feat-visual img{
  width:100%;height:100%;object-fit:contain;
  padding:2rem;position:relative;z-index:2;
  filter:drop-shadow(0 0 25px rgba(61,143,224,.5));
  animation:logoFloat 5s ease-in-out infinite;
}
.feat-list{display:flex;flex-direction:column;gap:1.4rem}
.feat-item{
  display:flex;gap:1rem;align-items:flex-start;
  padding:1.4rem;border:1px solid var(--border);border-radius:12px;
  background:var(--bg2);transition:all .3s;cursor:default;
}
.feat-item:hover{border-color:rgba(61,143,224,.45);background:rgba(61,143,224,.05);transform:translateX(4px)}
.feat-ico{
  width:40px;height:40px;border-radius:10px;flex-shrink:0;
  background:rgba(61,143,224,.12);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;font-size:1.1rem;
}
.feat-txt-title{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;color:var(--white);margin-bottom:.3rem}
.feat-txt-desc{font-size:.83rem;color:var(--muted);line-height:1.55}

/* ── NUMBERS ── */
.numbers-bg{
  background:linear-gradient(90deg,var(--blue-dark),var(--blue),var(--blue-dark));
  border-top:1px solid rgba(255,255,255,.08);
  border-bottom:1px solid rgba(255,255,255,.08);
}
.numbers-inner{
  max-width:1200px;margin:0 auto;padding:4.5rem 5vw;
  display:grid;grid-template-columns:repeat(4,1fr);gap:2px;
}
.num-block{
  text-align:center;padding:2rem 1rem;position:relative;
}
.num-block::after{
  content:'';position:absolute;right:0;top:20%;bottom:20%;
  width:1px;background:rgba(255,255,255,.12);
}
.num-block:last-child::after{display:none}
.num-val{
  font-family:'Syne',sans-serif;font-size:2.8rem;font-weight:800;
  color:#fff;line-height:1;
}
.num-lbl{font-size:.78rem;font-weight:500;color:rgba(255,255,255,.65);margin-top:.5rem;letter-spacing:.06em}

/* ── PRICING ── */
.pricing-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1.5rem;margin-top:4rem;
}
.price-card{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:18px;padding:2.2rem;
  position:relative;overflow:hidden;transition:transform .3s,box-shadow .3s;
}
.price-card:hover{transform:translateY(-6px);box-shadow:0 20px 50px rgba(0,0,0,.4)}
.price-card.popular{
  border-color:var(--blue);
  box-shadow:0 0 40px rgba(61,143,224,.2);
}
.popular-badge{
  position:absolute;top:0;right:0;
  background:var(--blue);color:#fff;
  font-size:.6rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  padding:.35rem .9rem;border-radius:0 18px 0 10px;
}
.price-plan{font-family:'Syne',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:.8rem}
.price-amount{
  font-family:'Syne',sans-serif;font-size:2.6rem;font-weight:800;
  color:var(--white);line-height:1;margin-bottom:.3rem;
}
.price-amount sub{font-size:1rem;vertical-align:super;margin-right:.1rem}
.price-period{font-size:.78rem;color:var(--muted)}
.price-divider{height:1px;background:var(--border);margin:1.5rem 0}
.price-features{list-style:none;display:flex;flex-direction:column;gap:.8rem;margin-bottom:2rem}
.price-features li{font-size:.87rem;color:var(--muted);display:flex;align-items:center;gap:.6rem}
.price-features li::before{content:'✓';color:var(--blue-light);font-weight:700;font-size:.9rem;flex-shrink:0}
.price-cta{
  display:block;text-align:center;text-decoration:none;
  font-family:'Syne',sans-serif;font-size:.88rem;font-weight:700;
  padding:.7rem;border-radius:10px;transition:all .25s;
}
.price-cta-ghost{border:1px solid var(--border);color:var(--text)}
.price-cta-ghost:hover{border-color:var(--blue);background:rgba(61,143,224,.08)}
.price-cta-fill{background:var(--blue);color:#fff;box-shadow:0 0 20px rgba(61,143,224,.35)}
.price-cta-fill:hover{background:var(--blue-light)}

/* ── TESTIMONIALS ── */
.testi-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1.5rem;margin-top:4rem;
}
.testi-card{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:16px;padding:2rem;
  transition:border-color .3s;
}
.testi-card:hover{border-color:rgba(61,143,224,.4)}
.testi-stars{display:flex;gap:3px;margin-bottom:1rem}
.testi-stars span{color:#ffd700;font-size:.85rem}
.testi-text{font-size:.9rem;color:var(--muted);line-height:1.7;margin-bottom:1.5rem}
.testi-author{display:flex;align-items:center;gap:.75rem}
.testi-av{
  width:38px;height:38px;border-radius:50%;
  background:linear-gradient(135deg,var(--blue-dark),var(--blue));
  display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-size:.85rem;font-weight:800;color:#fff;
  flex-shrink:0;
}
.testi-name{font-family:'Syne',sans-serif;font-size:.88rem;font-weight:700;color:var(--white)}
.testi-role{font-size:.75rem;color:var(--muted)}

/* ── CTA SECTION ── */
.cta-section{
  margin:0 5vw 6rem;
  background:linear-gradient(135deg,var(--bg2) 0%,rgba(61,143,224,.08) 50%,var(--bg2) 100%);
  border:1px solid var(--border);border-radius:24px;
  padding:5rem 4rem;text-align:center;position:relative;overflow:hidden;
}
.cta-section::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 60% at 50% 50%,rgba(61,143,224,.12) 0%,transparent 70%);
  pointer-events:none;
}
.cta-logo{
  width:60px;margin:0 auto 1.5rem;
  filter:brightness(0) invert(1) drop-shadow(0 0 20px rgba(61,143,224,.6));
  animation:logoFloat 5s ease-in-out infinite;
  position:relative;z-index:1;
}
.cta-title{
  font-family:'Syne',sans-serif;font-size:clamp(2rem,3.5vw,3rem);
  font-weight:800;color:var(--white);margin-bottom:1rem;
  line-height:1.15;position:relative;z-index:1;
}
.cta-desc{font-size:1rem;color:var(--muted);margin-bottom:2.5rem;max-width:460px;margin-left:auto;margin-right:auto;line-height:1.7;position:relative;z-index:1}
.cta-actions{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;position:relative;z-index:1}

/* ── FOOTER ── */
footer{
  background:var(--bg);border-top:1px solid var(--border);
  padding:4rem 5vw 2rem;
}
.footer-top{
  display:grid;grid-template-columns:2fr 1fr 1fr 1fr;
  gap:3rem;margin-bottom:3.5rem;
}
.footer-brand{}
.footer-logo-row{display:flex;align-items:center;gap:10px;margin-bottom:1rem}
.footer-logo-row img{width:28px;filter:brightness(0) invert(1)}
.footer-logo-row span{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:var(--white)}
.footer-logo-row span em{color:var(--blue-light);font-style:normal}
.footer-tagline{font-size:.85rem;color:var(--muted);line-height:1.65;max-width:260px}
.footer-col h4{
  font-family:'Syne',sans-serif;font-size:.65rem;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--muted);
  margin-bottom:1.2rem;
}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.7rem}
.footer-col ul a{font-size:.87rem;color:rgba(255,255,255,.45);text-decoration:none;transition:color .2s}
.footer-col ul a:hover{color:var(--blue-light)}
.footer-bottom{
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;
  padding-top:2rem;border-top:1px solid var(--border);
}
.footer-copy{font-size:.75rem;color:rgba(255,255,255,.25)}
.footer-socials{display:flex;gap:1rem}
.soc-btn{
  width:34px;height:34px;border-radius:8px;
  background:rgba(255,255,255,.05);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:.9rem;text-decoration:none;color:var(--muted);
  transition:all .2s;
}
.soc-btn:hover{background:rgba(61,143,224,.15);border-color:var(--blue);color:var(--blue-light)}

/* ── SCROLL REVEAL ── */
.reveal{opacity:0;transform:translateY(30px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr;text-align:center}
  .hero-right{display:none}
  .hero-desc,.hero-stats{margin-left:auto;margin-right:auto}
  .hero-actions{justify-content:center}
  .services-grid,.features-inner,.pricing-grid,.testi-grid{grid-template-columns:1fr}
  .numbers-inner{grid-template-columns:1fr 1fr}
  .footer-top{grid-template-columns:1fr 1fr}
  .nav-links{display:none}
  .cta-section{padding:3rem 2rem}
}
</style>
</head>
<body>

<div id="cur"></div>
<div id="curR"></div>

<!-- ═══ NAV ═══ -->
